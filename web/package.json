{
  "name": "@olvid/bot-web",
  "type": "commonjs",
  "main": "./dist/olvid.cjs.min.js",
  "module": "./dist/olvid.esm.min.js",
  "types": "./dist/olvid.d.ts",
  "exports": {
    ".": {
      "types": "./dist/olvid.d.ts",
      "require": "./dist/olvid.cjs.min.js",
      "import": "./dist/olvid.esm.min.js"
    }
  },
  "version": "2.0.0-alpha.2",
  "files": [
    "README.md",
    "LICENSE",
    "package.json",
    "./src/**/*",
    "./dist/**/*"
  ],
  "exclude": [
    "test"
  ],
  "directories": {
    "src": "src",
    "dist": "dist"
  },
  "homepage": "https://doc.bot.olvid.io",
  "repository": {
    "url": "git+https://github.com/olvid-io/Olvid-Bot-Js-Client.git"
  },
  "keywords": [
    "olvid",
    "daemon",
    "bot",
    "standalone",
    "browser"
  ],
  "author": "bot@olvid.io",
  "license": "LICENSE",
  "description": "Develop Olvid Bots in a web browser.",
  "scripts": {
    "generate": "npx buf generate",
    "build": "tsup",
    "lint": "publint",
    "prepublishOnly": "npm run generate && npm run build",
    "push": "npm run build && echo 'YOU ARE ABOUT TO PUSH IN PROD (CTRL+C TO ABORT)' && read && npm publish"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.9.0",
    "@connectrpc/connect-web": "^2.1.0",
    "events": "^3.3.0",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.54.0",
    "@bufbuild/protoc-gen-es": "^2.8.0",
    "@swc/core": "^1.11.29",
    "@types/node": "^22.15.23",
    "publint": "^0.2.12",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3"
  }
}
