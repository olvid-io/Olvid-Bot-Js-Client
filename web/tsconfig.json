{
  "include": ["src/**/*"],
  "compilerOptions": {
    "lib": ["ES2015", "ES2018", "ES2020", "dom"],
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "target": "es5",
    "allowJs": false,
    "declaration": true,
    "declarationMap": true,
    "removeComments": false,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "inlineSourceMap": true,
  }
}
